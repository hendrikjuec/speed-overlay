<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs Security Filter - Focus on Security-relevant findings
  Place in project root as spotbugs-security-filter.xml
-->
<FindBugsFilter>
    <!-- Include all FindSecBugs rules -->
    <Match>
        <Bug category="SECURITY"/>
    </Match>

    <!-- SQL Injection -->
    <Match>
        <Bug pattern="SQL_INJECTION_JDBC"/>
    </Match>
    <Match>
        <Bug pattern="SQL_INJECTION_JPA"/>
    </Match>
    <Match>
        <Bug pattern="SQL_INJECTION_SPRING_JDBC"/>
    </Match>

    <!-- XSS -->
    <Match>
        <Bug pattern="XSS_REQUEST_WRAPPER"/>
    </Match>
    <Match>
        <Bug pattern="XSS_SERVLET"/>
    </Match>

    <!-- Path Traversal -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
    </Match>
    <Match>
        <Bug pattern="PATH_TRAVERSAL_OUT"/>
    </Match>

    <!-- Crypto -->
    <Match>
        <Bug pattern="WEAK_TRUST_MANAGER"/>
    </Match>
    <Match>
        <Bug pattern="WEAK_HOSTNAME_VERIFIER"/>
    </Match>
    <Match>
        <Bug pattern="HARD_CODE_PASSWORD"/>
    </Match>
    <Match>
        <Bug pattern="HARD_CODE_KEY"/>
    </Match>

    <!-- Deserialization -->
    <Match>
        <Bug pattern="OBJECT_DESERIALIZATION"/>
    </Match>

    <!-- Command Injection -->
    <Match>
        <Bug pattern="COMMAND_INJECTION"/>
    </Match>

    <!-- LDAP Injection -->
    <Match>
        <Bug pattern="LDAP_INJECTION"/>
    </Match>

    <!-- XXE -->
    <Match>
        <Bug pattern="XXE_SAXPARSER"/>
    </Match>
    <Match>
        <Bug pattern="XXE_XMLREADER"/>
    </Match>
    <Match>
        <Bug pattern="XXE_DOCUMENT"/>
    </Match>
</FindBugsFilter>
