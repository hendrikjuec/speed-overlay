# =============================================================================
# .env.example Template - Security Best Practice
# Copy to .env and fill in actual values (NEVER commit .env!)
# =============================================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=false
APP_PORT=8080

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# --- Authentication ---
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
JWT_EXPIRY=3600

# --- External APIs ---
API_KEY=CHANGE_ME
API_SECRET=CHANGE_ME

# --- Azure ---
AZURE_TENANT_ID=CHANGE_ME
AZURE_CLIENT_ID=CHANGE_ME
AZURE_CLIENT_SECRET=CHANGE_ME
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net/

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
