<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_bg"
    android:padding="12dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Zusatz-Info Zeile (Blitzer, Gefahr) -->
    <LinearLayout
        android:id="@+id/info_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp">

        <ImageView
            android:id="@+id/iv_hazard"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_warning"
            android:layout_marginEnd="4dp"
            android:visibility="gone"
            android:contentDescription="Gefahr"
            app:tint="#FF5252" />

        <ImageView
            android:id="@+id/iv_camera"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_camera"
            android:visibility="gone"
            android:contentDescription="Blitzer"
            app:tint="#FFD740" />
    </LinearLayout>

    <!-- Speed Limit Circle -->
    <TextView
        android:id="@+id/speed_limit_text"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/speed_limit_bg"
        android:gravity="center"
        android:text="--"
        android:textColor="#000000"
        android:textSize="18dp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/info_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Current Speed -->
    <TextView
        android:id="@+id/current_speed_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="32dp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/speed_limit_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-4dp" />

    <!-- Unit -->
    <TextView
        android:id="@+id/unit_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="km/h"
        android:textColor="#BBBBBB"
        android:textSize="12dp"
        app:layout_constraintTop_toBottomOf="@id/current_speed_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Ton Status Icon oben rechts -->
    <ImageView
        android:id="@+id/iv_mute_status"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_notifications"
        android:contentDescription="Ton Status"
        app:tint="#C0FFFFFF"
        android:padding="2dp"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-6dp"
        android:layout_marginEnd="-6dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
