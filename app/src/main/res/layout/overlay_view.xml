<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_bg"
    android:padding="10dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="6dp">

        <!-- Zusatz-Info Zeile (Blitzer, Gefahr, Schule) -->
        <LinearLayout
            android:id="@+id/info_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_hazard"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_warning"
                android:layout_marginEnd="4dp"
                android:visibility="gone"
                android:contentDescription="Gefahr"
                app:tint="#FF5252" />

            <ImageView
                android:id="@+id/iv_camera"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_camera"
                android:visibility="gone"
                android:contentDescription="Blitzer"
                app:tint="#FFD740" />
        </LinearLayout>

        <TextView
            android:id="@+id/speed_limit_text"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/speed_limit_bg"
            android:gravity="center"
            android:text="--"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/current_speed_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="-2dp" />

        <TextView
            android:id="@+id/unit_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="km/h"
            android:textColor="#BBBBBB"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Ton Status Icon oben rechts - Deutlich vergrößert -->
    <ImageView
        android:id="@+id/iv_mute_status"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:src="@drawable/ic_notifications"
        android:contentDescription="Ton Status"
        app:tint="#C0FFFFFF"
        android:padding="2dp"
        android:visibility="visible" />

</FrameLayout>
